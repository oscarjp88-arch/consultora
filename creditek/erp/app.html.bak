<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creditek · ERP</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="sidebar.js"></script>
<style>
:root {
  --azul: #0B1E3D;
  --turquesa: #00C4CC;
  --bg: #F5F5F7;
  --surface: #FFFFFF;
  --border: rgba(11,30,61,0.08);
  --text2: #6E6E76;
  --verde: #16A34A;
  --amarillo: #D97706;
  --rojo: #DC2626;
  --radius: 18px;
  --radius-sm: 11px;
  --shadow-sm: 0 1px 2px rgba(11,30,61,0.04), 0 1px 1px rgba(11,30,61,0.03);
  --shadow-md: 0 12px 28px -10px rgba(11,30,61,0.16);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
  background: var(--bg); color: var(--azul);
  -webkit-font-smoothing: antialiased;
}

/* ── Login ── */
.login-screen { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; background: radial-gradient(circle at 30% 20%, #EAFBFC 0%, var(--bg) 55%); }
.login-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; width: 100%; max-width: 360px; box-shadow: var(--shadow-md); }
.login-box img.logo { display: block; height: 40px; margin: 0 auto 22px; object-fit: contain; }
.login-box input {
  width: 100%; border: 1px solid transparent; background: var(--bg); border-radius: var(--radius-sm);
  padding: 13px 14px; font-size: 15px; margin-bottom: 12px; font-family: inherit; transition: all .15s ease;
}
.login-box input:focus { outline: none; background: white; border-color: var(--turquesa); box-shadow: 0 0 0 4px rgba(0,196,204,0.14); }
.login-box button {
  width: 100%; background: var(--turquesa); color: white; border: none; border-radius: var(--radius-sm);
  padding: 13px; font-size: 14.5px; font-weight: 700; cursor: pointer; margin-top: 6px;
  box-shadow: 0 6px 16px -4px rgba(0,196,204,0.5); transition: transform .12s ease, box-shadow .12s ease;
}
.login-box button:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 8px 20px -4px rgba(0,196,204,0.55); }
.login-box button:disabled { background: #D2D2D7; box-shadow: none; }
.login-err { color: var(--rojo); font-size: 12.5px; margin-top: 10px; display: none; }
.login-err.show { display: block; }

/* ── Sin perfil ── */
.sin-perfil-screen { min-height: 100vh; display: none; align-items: center; justify-content: center; padding: 20px; text-align: center; }
.sin-perfil-screen.show { display: flex; }
.sin-perfil-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; max-width: 380px; box-shadow: var(--shadow-md); }
.sin-perfil-box .icono { font-size: 34px; margin-bottom: 12px; }
.sin-perfil-box h2 { font-family: 'Montserrat', sans-serif; font-size: 17px; margin-bottom: 8px; }
.sin-perfil-box p { font-size: 13.5px; color: var(--text2); line-height: 1.5; margin-bottom: 18px; }
.sin-perfil-box button { border: 1px solid var(--border); background: var(--bg); border-radius: var(--radius-sm); padding: 10px 18px; font-size: 13px; cursor: pointer; color: var(--azul); font-weight: 600; }

/* ── App shell ── */
#app { display: none; }
#app.show { display: flex; }

.navbar {
  background: rgba(255,255,255,0.72);
  backdrop-filter: saturate(180%) blur(20px);
  -webkit-backdrop-filter: saturate(180%) blur(20px);
  border-bottom: 1px solid var(--border);
  padding: 12px 24px; display: flex; align-items: center; gap: 18px;
  position: sticky; top: 0; z-index: 10; flex-wrap: wrap;
}
.navbar img.logo { height: 26px; object-fit: contain; flex-shrink: 0; }
.nav-links { display: flex; gap: 4px; overflow-x: auto; flex: 1; scrollbar-width: none; }
.nav-links::-webkit-scrollbar { display: none; }
.nav-links a {
  white-space: nowrap; text-decoration: none; color: var(--text2); font-size: 13px; font-weight: 600;
  padding: 8px 14px; border-radius: 999px; transition: background .15s ease, color .15s ease;
}
.nav-links a:hover { background: rgba(11,30,61,0.05); color: var(--azul); }
.nav-links a.active { background: var(--azul); color: white; box-shadow: var(--shadow-sm); }
.nav-user { display: flex; align-items: center; gap: 12px; font-size: 12px; color: var(--text2); flex-shrink: 0; }
.nav-user .quien { text-align: right; line-height: 1.3; }
.nav-user .quien b { color: var(--azul); font-size: 12.5px; }
.nav-user button {
  background: var(--bg); border: 1px solid var(--border); border-radius: 999px; padding: 7px 14px;
  font-size: 12px; cursor: pointer; color: var(--text2); font-weight: 600; transition: background .15s ease;
}
.nav-user button:hover { background: #EAEAEC; }

.page { max-width: 1100px; margin: 0 auto; padding: 32px 24px 60px; }

/* ── Home (app.html) ── */
.bienvenida { margin-bottom: 26px; }
.bienvenida h1 { font-family: 'Montserrat', sans-serif; font-size: 26px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 6px; }
.bienvenida p { font-size: 14px; color: var(--text2); }
.kpis { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
.kpi-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px;
  box-shadow: var(--shadow-sm); transition: box-shadow .2s ease, transform .2s ease;
}
.kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.kpi-label {
  display: flex; align-items: center; gap: 7px; font-size: 11.5px; font-weight: 700; text-transform: uppercase;
  letter-spacing: .04em; color: var(--text2); margin-bottom: 12px;
}
.kpi-valor { font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: 27px; letter-spacing: -0.01em; }
.kpi-valor.loading { color: var(--text2); font-size: 15px; font-weight: 600; }
.kpi-sub { font-size: 12px; color: var(--text2); margin-top: 6px; }
</style>
</head>
<body>

<div class="login-screen" id="loginScreen">
  <div class="login-box">
    <img class="logo" src="https://oscarjp88-arch.github.io/consultora/creditek/agentes/logos/creditek_logo_corregido_alta.png" alt="Creditek">
    <input type="email" id="loginEmail" placeholder="Correo" autocomplete="username">
    <input type="password" id="loginPass" placeholder="Contraseña" autocomplete="current-password">
    <button id="btnLogin">Entrar</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<div class="sin-perfil-screen" id="sinPerfilScreen">
  <div class="sin-perfil-box">
    <div class="icono">🔒</div>
    <h2>Sin perfil asignado</h2>
    <p>Tu usuario no tiene perfil asignado. Contacta al administrador.</p>
    <button id="btnSalirSinPerfil">Cerrar sesión</button>
  </div>
</div>

<div id="app">
  <div style="display:none;" aria-hidden="true">
    <b id="navNombre"></b><span id="navRolTienda"></span><button id="btnLogout"></button>
  </div>
  <div class="main-content">

  <div class="page">
    <div class="bienvenida">
      <h1 id="saludo">Hola</h1>
      <p id="subSaludo"></p>
    </div>
    <div class="kpis">
      <div class="kpi-card">
        <div class="kpi-label">💰 Ventas hoy</div>
        <div class="kpi-valor loading" id="kpiVentasHoy">Cargando...</div>
        <div class="kpi-sub" id="kpiVentasHoySub"></div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">💳 Créditos hoy</div>
        <div class="kpi-valor loading" id="kpiCreditos">Cargando...</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">✅ Clientes pendientes</div>
        <div class="kpi-valor loading" id="kpiPendientes">Cargando...</div>
      </div>
      <div class="kpi-card">
        <div class="kpi-label">🗄️ Caja</div>
        <div class="kpi-valor loading" id="kpiCaja">Cargando...</div>
      </div>
    </div>
  </div>
  </div>
</div>

<script>
// Proyecto Supabase "creditek-erp" — separado por completo del proyecto de Sofía.
const SUPABASE_URL = 'https://jfkmiyvcdfbsbwchyvol.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impma21peXZjZGZic2J3Y2h5dm9sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQxMzA5NjgsImV4cCI6MjA5OTcwNjk2OH0.kpAjGLbDnycU-B1kc-AqOvj6X2xH-KHBiKB94V7prcQ';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let currentPerfil = null; // { id, nombre, rol, tienda_codigo }

function esCentral() {
  return !!currentPerfil && (currentPerfil.rol === 'gerencia' || currentPerfil.rol === 'auditoria');
}

document.getElementById('btnLogin').addEventListener('click', hacerLogin);
document.getElementById('loginPass').addEventListener('keydown', (e) => { if (e.key === 'Enter') hacerLogin(); });

async function hacerLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const password = document.getElementById('loginPass').value;
  const btn = document.getElementById('btnLogin');
  const err = document.getElementById('loginErr');
  err.classList.remove('show');
  if (!email || !password) return;
  btn.disabled = true;
  btn.textContent = 'Entrando...';
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  btn.disabled = false;
  btn.textContent = 'Entrar';
  if (error) {
    err.textContent = 'Correo o contraseña incorrectos.';
    err.classList.add('show');
    return;
  }
  entrarApp(data.user);
}

document.getElementById('btnLogout').addEventListener('click', cerrarSesion);
document.getElementById('btnSalirSinPerfil').addEventListener('click', cerrarSesion);
async function cerrarSesion() {
  await sb.auth.signOut();
  location.reload();
}

async function entrarApp(user) {
  currentUser = user;
  const { data: perfil, error } = await sb.from('perfiles').select('*').eq('id', user.id).maybeSingle();
  if (error || !perfil || !perfil.activo) {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('sinPerfilScreen').classList.add('show');
    return;
  }
  currentPerfil = perfil;

  // Primer ingreso: admin_tienda debe cambiar la contraseña temporal antes de usar el ERP.
  const yaCambioClave = !!(user.user_metadata && user.user_metadata.password_cambiada);
  if (perfil.rol === 'admin_tienda' && !yaCambioClave) {
    location.href = 'cambiar-clave.html';
    return;
  }

  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('app').classList.add('show');
  pintarNavUser();
  if (typeof initPagina === 'function') initPagina();
}

function pintarNavUser() {
  document.getElementById('navNombre').textContent = currentPerfil.nombre || currentUser.email;
  const rolLabel = { gerencia: 'Gerencia', auditoria: 'Auditoría', admin_tienda: 'Admin tienda', asesor: 'Asesor' }[currentPerfil.rol] || currentPerfil.rol;
  document.getElementById('navRolTienda').textContent = currentPerfil.tienda_codigo ? `${rolLabel} · ${currentPerfil.tienda_codigo}` : rolLabel;

  const saludo = document.getElementById('saludo');
  const sub = document.getElementById('subSaludo');
  if (saludo) saludo.textContent = `Hola, ${(currentPerfil.nombre || '').split(' ')[0] || ''}`;
  if (sub) sub.textContent = esCentral()
    ? 'Tienes acceso a todas las tiendas.'
    : `Estás viendo la información de ${currentPerfil.tienda_codigo || 'tu tienda'}.`;
}

// Restaurar sesión si ya existe (evita re-login en cada recarga)
sb.auth.getSession().then(({ data }) => {
  if (data.session) entrarApp(data.session.user);
});

function fmtCOP(n) {
  return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n || 0);
}
function escapeHtml(str) {
  if (str === null || str === undefined) return '';
  return String(str).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
}

function hoyISO() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
}

async function initPagina() {
  const hoy = hoyISO();
  const esC = esCentral();
  const tienda = currentPerfil.tienda_codigo;
  const elVentas = document.getElementById('kpiVentasHoy');
  const elVentasSub = document.getElementById('kpiVentasHoySub');
  const elCreditos = document.getElementById('kpiCreditos');
  const elPendientes = document.getElementById('kpiPendientes');
  const elCaja = document.getElementById('kpiCaja');

  try {
    // Ventas hoy + créditos hoy (una sola consulta)
    let qv = sb.from('ventas').select('total, tipo').eq('fecha', hoy).eq('anulada', false);
    if (!esC) qv = qv.eq('tienda_codigo', tienda);
    const { data: ventasHoy, error: errVentas } = await qv;
    if (errVentas) throw errVentas;
    const totalVentas = (ventasHoy || []).reduce((s, v) => s + Number(v.total || 0), 0);
    const totalCreditos = (ventasHoy || []).filter(v => v.tipo === 'credito').length;
    elVentas.textContent = fmtCOP(totalVentas);
    elVentas.classList.remove('loading');
    elVentasSub.textContent = esC ? 'Todas las tiendas' : (tienda || '');
    elCreditos.textContent = `${totalCreditos} ${totalCreditos === 1 ? 'operación' : 'operaciones'}`;
    elCreditos.classList.remove('loading');
  } catch (e) {
    elVentas.textContent = '—'; elVentas.classList.remove('loading');
    elCreditos.textContent = '—'; elCreditos.classList.remove('loading');
  }

  try {
    // Clientes pendientes — misma definición que validacion.html (global, sin filtro de tienda)
    const { count, error: errSol } = await sb.from('solicitudes').select('id', { count: 'exact', head: true }).eq('estado_validacion', 'pendiente');
    if (errSol) throw errSol;
    elPendientes.textContent = `${count ?? 0}`;
    elPendientes.classList.remove('loading');
  } catch (e) {
    elPendientes.textContent = '—'; elPendientes.classList.remove('loading');
  }

  try {
    if (esC) {
      const { data: tiendasProp, error: errT } = await sb.from('origenes').select('codigo').eq('tipo', 'propia').eq('activo', true);
      if (errT) throw errT;
      const { data: cajasHoy, error: errC } = await sb.from('caja_diaria').select('tienda_codigo, estado').eq('fecha', hoy);
      if (errC) throw errC;
      const cerradas = (cajasHoy || []).filter(c => c.estado === 'cerrada').length;
      elCaja.textContent = `${cerradas}/${(tiendasProp || []).length} cerradas`;
    } else {
      const { data: cajaHoy, error: errC } = await sb.from('caja_diaria').select('estado').eq('fecha', hoy).eq('tienda_codigo', tienda).maybeSingle();
      if (errC) throw errC;
      elCaja.textContent = cajaHoy ? (cajaHoy.estado === 'cerrada' ? 'Cerrada' : 'Abierta') : 'Sin abrir';
    }
    elCaja.classList.remove('loading');
  } catch (e) {
    elCaja.textContent = '—'; elCaja.classList.remove('loading');
  }
}
</script>
</body>
</html>
