<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creditek · Presupuestos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="sidebar.js"></script>
<style>
:root {
  --azul: #0B1E3D; --turquesa: #00C4CC; --bg: #F5F5F7; --surface: #FFFFFF;
  --border: rgba(11,30,61,0.08); --text2: #6E6E76; --verde: #16A34A; --amarillo: #D97706; --rojo: #DC2626;
  --radius: 18px; --radius-sm: 11px;
  --shadow-sm: 0 1px 2px rgba(11,30,61,0.04), 0 1px 1px rgba(11,30,61,0.03);
  --shadow-md: 0 12px 28px -10px rgba(11,30,61,0.16);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--azul); -webkit-font-smoothing: antialiased; }

.login-screen { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; background: radial-gradient(circle at 30% 20%, #EAFBFC 0%, var(--bg) 55%); }
.login-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; width: 100%; max-width: 360px; box-shadow: var(--shadow-md); }
.login-box img.logo { display: block; height: 40px; margin: 0 auto 22px; object-fit: contain; }
.login-box input { width: 100%; border: 1px solid transparent; background: var(--bg); border-radius: var(--radius-sm); padding: 13px 14px; font-size: 15px; margin-bottom: 12px; font-family: inherit; transition: all .15s ease; }
.login-box input:focus { outline: none; background: white; border-color: var(--turquesa); box-shadow: 0 0 0 4px rgba(0,196,204,0.14); }
.login-box button { width: 100%; background: var(--turquesa); color: white; border: none; border-radius: var(--radius-sm); padding: 13px; font-size: 14.5px; font-weight: 700; cursor: pointer; margin-top: 6px; box-shadow: 0 6px 16px -4px rgba(0,196,204,0.5); transition: transform .12s ease, box-shadow .12s ease; }
.login-box button:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 8px 20px -4px rgba(0,196,204,0.55); }
.login-box button:disabled { background: #D2D2D7; box-shadow: none; }
.login-err { color: var(--rojo); font-size: 12.5px; margin-top: 10px; display: none; }
.login-err.show { display: block; }

.sin-perfil-screen { min-height: 100vh; display: none; align-items: center; justify-content: center; padding: 20px; text-align: center; }
.sin-perfil-screen.show { display: flex; }
.sin-perfil-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; max-width: 380px; box-shadow: var(--shadow-md); }
.sin-perfil-box .icono { font-size: 34px; margin-bottom: 12px; }
.sin-perfil-box h2 { font-family: 'Montserrat', sans-serif; font-size: 17px; margin-bottom: 8px; }
.sin-perfil-box p { font-size: 13.5px; color: var(--text2); line-height: 1.5; margin-bottom: 18px; }
.sin-perfil-box button { border: 1px solid var(--border); background: var(--bg); border-radius: var(--radius-sm); padding: 10px 18px; font-size: 13px; cursor: pointer; color: var(--azul); font-weight: 600; }

#app { display: none; }
#app.show { display: flex; }

.page { max-width: 1280px; margin: 0 auto; padding: 32px 24px 60px; }
.page-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
.page-top h1 { font-family: 'Montserrat', sans-serif; font-size: 22px; font-weight: 800; letter-spacing: -0.02em; }
.acceso-negado { text-align: center; padding: 80px 20px; color: var(--text2); }
.acceso-negado .icono { font-size: 34px; margin-bottom: 12px; }

.btn-primary { background: var(--turquesa); color: white; border: none; border-radius: 999px; padding: 11px 18px; font-size: 13.5px; font-weight: 700; cursor: pointer; box-shadow: 0 6px 16px -4px rgba(0,196,204,0.5); transition: transform .12s ease; }
.btn-primary:hover:not(:disabled) { transform: translateY(-1px); }
.btn-primary:disabled { background: #D2D2D7; box-shadow: none; cursor: not-allowed; }
.btn-secundario { background: var(--bg); color: var(--azul); border: 1px solid var(--border); border-radius: 999px; padding: 9px 16px; font-size: 13px; font-weight: 700; cursor: pointer; }

.banner-ok {
  position: sticky; top: 14px; z-index: 8; margin: 0 auto 18px; max-width: 1280px;
  background: #DCFCE7; color: #166534; border: 1px solid #86EFAC; border-radius: var(--radius-sm);
  padding: 13px 18px; font-size: 13.5px; font-weight: 700; display: none; align-items: center; justify-content: space-between;
  box-shadow: var(--shadow-sm);
}
.banner-ok.show { display: flex; }
.banner-ok button { background: none; border: none; color: #166534; font-weight: 700; cursor: pointer; font-size: 16px; }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 20px 22px; margin-bottom: 22px; box-shadow: var(--shadow-sm); }
.card h2 { font-family: 'Montserrat', sans-serif; font-size: 15px; margin-bottom: 4px; }
.card .sub { font-size: 12.5px; color: var(--text2); margin-bottom: 14px; }
.form-inline { display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end; }
.campo { margin-bottom: 0; }
.campo label { display: block; font-size: 12px; color: var(--text2); margin-bottom: 5px; font-weight: 600; }
.campo input, .campo select { border: 1px solid transparent; background: var(--bg); border-radius: var(--radius-sm); padding: 10px 12px; font-size: 13.5px; font-family: inherit; transition: all .15s ease; }
.campo input:focus, .campo select:focus { outline: none; background: white; border-color: var(--turquesa); box-shadow: 0 0 0 3px rgba(0,196,204,0.12); }
.modal-err { color: var(--rojo); font-size: 12.5px; margin-top: 8px; display: none; }
.modal-err.show { display: block; }
.modal-ok { color: var(--verde); font-size: 12.5px; margin-top: 8px; display: none; }
.modal-ok.show { display: block; }

.tabs { display: flex; gap: 6px; margin-bottom: 16px; }
.tabs button { background: var(--bg); border: 1px solid var(--border); border-radius: 999px; padding: 8px 16px; font-size: 12.5px; font-weight: 700; cursor: pointer; color: var(--text2); }
.tabs button.activo { background: var(--azul); color: white; border-color: var(--azul); }

.tabla-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: auto; box-shadow: var(--shadow-sm); max-height: 65vh; }
table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
th, td { text-align: center; padding: 8px 9px; border-bottom: 1px solid var(--border); white-space: nowrap; }
th { background: rgba(11,30,61,0.02); font-size: 10.5px; text-transform: uppercase; letter-spacing: .03em; color: var(--text2); font-weight: 700; position: sticky; top: 0; z-index: 2; }
td.tienda-nombre, th.tienda-nombre { text-align: left; position: sticky; left: 0; background: var(--surface); z-index: 1; font-weight: 700; min-width: 140px; }
th.tienda-nombre { z-index: 3; background: rgba(11,30,61,0.04); }
td.total-mes, th.total-mes { position: sticky; right: 0; background: var(--surface); font-weight: 700; z-index: 1; }
th.total-mes { z-index: 3; background: rgba(11,30,61,0.04); }
td.dia-celda { cursor: pointer; }
td.dia-celda:hover { background: rgba(0,196,204,0.08); }
td.finde { background: rgba(11,30,61,0.02); }
td.manual { color: var(--turquesa); font-weight: 700; }
.celda-input { width: 42px; text-align: center; border: 1px solid var(--turquesa); border-radius: 6px; padding: 3px; font-size: 12.5px; font-family: inherit; }
.empty-state { text-align: center; color: var(--text2); font-size: 14px; padding: 40px 0; }

.modal-bg { display: none; position: fixed; inset: 0; background: rgba(11,30,61,0.35); backdrop-filter: blur(4px); align-items: center; justify-content: center; z-index: 50; padding: 16px; }
.modal-bg.show { display: flex; }
.modal-box { background: var(--surface); border-radius: 20px; padding: 26px 24px; width: 100%; max-width: 460px; max-height: 92vh; overflow-y: auto; box-shadow: var(--shadow-md); }
.modal-box h2 { font-family: 'Montserrat', sans-serif; font-size: 17px; margin-bottom: 4px; }
.modal-sub { font-size: 12.5px; color: var(--text2); margin-bottom: 16px; }
.modal-actions { display: flex; gap: 8px; margin-top: 18px; }
.modal-actions button { flex: 1; border: none; border-radius: 999px; padding: 12px; font-size: 13.5px; font-weight: 700; cursor: pointer; }
.modal-actions .btn-cancelar { background: var(--bg); color: var(--text2); flex: 0 0 auto; padding: 12px 20px; }
.modal-actions .btn-guardar { background: var(--turquesa); color: white; }
</style>
</head>
<body>

<div class="login-screen" id="loginScreen">
  <div class="login-box">
    <img class="logo" src="https://oscarjp88-arch.github.io/consultora/creditek/agentes/logos/creditek_logo_corregido_alta.png" alt="Creditek">
    <input type="email" id="loginEmail" placeholder="Correo" autocomplete="username">
    <input type="password" id="loginPass" placeholder="Contraseña" autocomplete="current-password">
    <button id="btnLogin">Entrar</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<div class="sin-perfil-screen" id="sinPerfilScreen">
  <div class="sin-perfil-box">
    <div class="icono">🔒</div>
    <h2>Sin perfil asignado</h2>
    <p>Tu usuario no tiene perfil asignado. Contacta al administrador.</p>
    <button id="btnSalirSinPerfil">Cerrar sesión</button>
  </div>
</div>

<div id="app">
  <div style="display:none;" aria-hidden="true">
    <b id="navNombre"></b><span id="navRolTienda"></span><button id="btnLogout"></button>
  </div>
  <div class="main-content">

  <div class="banner-ok" id="bannerOk">
    <span id="bannerOkTexto"></span>
    <button id="btnCerrarBanner">✕</button>
  </div>

  <div class="page" id="pageContenido"></div>
  </div>
</div>

<template id="tplAccesoNegado">
  <div class="acceso-negado">
    <div class="icono">🔒</div>
    <h2>Solo gerencia o auditoría</h2>
    <p>Los presupuestos no están disponibles para roles de tienda.</p>
  </div>
</template>

<template id="tplPresupuestos">
  <div class="page-top">
    <h1>Presupuestos</h1>
  </div>

  <div class="card">
    <h2>Generar presupuesto automático</h2>
    <div class="sub">Toma el histórico del mismo mes del año anterior (o el histórico importado, si existe) y lo distribuye por día respetando estacionalidad (lunes/martes más, domingo menos, quincenas pico). Si una tienda no tiene histórico, usa la meta base de 25 créditos/mes ya confirmada. Los días editados a mano no se sobrescriben.</div>
    <div class="form-inline">
      <div class="campo"><label>Mes</label><input type="month" id="genMes"></div>
      <div class="campo"><label>% de crecimiento</label><input type="number" id="genPct" value="0" step="1" style="width:90px;"></div>
      <button class="btn-primary" id="btnGenerar">Generar presupuesto</button>
      <button class="btn-secundario" id="btnImportarHistorico">Importar histórico (CSV)</button>
      <input type="file" id="inputHistorico" accept=".csv,.xlsx,.xls" style="display:none;">
    </div>
    <div class="modal-err" id="genErr"></div>
  </div>

  <div class="tabs">
    <button class="activo" id="tabCreditos" data-metrica="meta_creditos">Créditos</button>
    <button id="tabContado" data-metrica="meta_unidades_contado">Contado (unidades)</button>
    <button id="tabUtilidad" data-metrica="meta_utilidad">Utilidad</button>
  </div>

  <div class="form-inline" style="margin-bottom:12px;">
    <div class="campo"><label>Mes a ver</label><input type="month" id="verMes"></div>
  </div>

  <div class="tabla-wrap">
    <table id="tablaPresupuesto">
      <thead><tr id="theadFila"></tr></thead>
      <tbody id="tbodyPresupuesto"></tbody>
    </table>
    <div class="empty-state" id="emptyPresupuesto" style="display:none;">No hay presupuesto generado para este mes todavía.</div>
  </div>
</template>

<!-- Modal: editar celda -->
<div class="modal-bg" id="modalCelda">
  <div class="modal-box">
    <h2>Ajustar meta</h2>
    <div class="modal-sub" id="celdaContexto"></div>
    <div class="campo"><label id="celdaLabel">Meta</label><input type="number" id="celdaValor" min="0"></div>
    <div class="modal-err" id="celdaErr"></div>
    <div class="modal-actions">
      <button class="btn-cancelar" id="btnCancelarCelda">Cancelar</button>
      <button class="btn-guardar" id="btnGuardarCelda">Guardar</button>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://jfkmiyvcdfbsbwchyvol.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impma21peXZjZGZic2J3Y2h5dm9sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQxMzA5NjgsImV4cCI6MjA5OTcwNjk2OH0.kpAjGLbDnycU-B1kc-AqOvj6X2xH-KHBiKB94V7prcQ';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let currentPerfil = null;
let tiendasCache = [];
let presupuestoCache = [];
let metricaActual = 'meta_creditos';
let celdaEnEdicion = null;

function esCentral() { return !!currentPerfil && (currentPerfil.rol === 'gerencia' || currentPerfil.rol === 'auditoria'); }

document.getElementById('btnLogin').addEventListener('click', hacerLogin);
document.getElementById('loginPass').addEventListener('keydown', (e) => { if (e.key === 'Enter') hacerLogin(); });

async function hacerLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const password = document.getElementById('loginPass').value;
  const btn = document.getElementById('btnLogin');
  const err = document.getElementById('loginErr');
  err.classList.remove('show');
  if (!email || !password) return;
  btn.disabled = true; btn.textContent = 'Entrando...';
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  btn.disabled = false; btn.textContent = 'Entrar';
  if (error) { err.textContent = 'Correo o contraseña incorrectos.'; err.classList.add('show'); return; }
  entrarApp(data.user);
}

document.getElementById('btnLogout').addEventListener('click', cerrarSesion);
document.getElementById('btnSalirSinPerfil').addEventListener('click', cerrarSesion);
async function cerrarSesion() { await sb.auth.signOut(); location.reload(); }

async function entrarApp(user) {
  currentUser = user;
  const { data: perfil, error } = await sb.from('perfiles').select('*').eq('id', user.id).maybeSingle();
  if (error || !perfil || !perfil.activo) {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('sinPerfilScreen').classList.add('show');
    return;
  }
  currentPerfil = perfil;
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('app').classList.add('show');
  pintarNavUser();
  initPagina();
}

function pintarNavUser() {
  document.getElementById('navNombre').textContent = currentPerfil.nombre || currentUser.email;
  const rolLabel = { gerencia: 'Gerencia', auditoria: 'Auditoría', admin_tienda: 'Admin tienda', asesor: 'Asesor' }[currentPerfil.rol] || currentPerfil.rol;
  document.getElementById('navRolTienda').textContent = currentPerfil.tienda_codigo ? `${rolLabel} · ${currentPerfil.tienda_codigo}` : rolLabel;
}

sb.auth.getSession().then(({ data }) => { if (data.session) entrarApp(data.session.user); });

function fmtCOP(n) { return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n || 0); }
function escapeHtml(str) {
  if (str === null || str === undefined) return '';
  return String(str).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
}
function mostrarBanner(texto) {
  document.getElementById('bannerOkTexto').textContent = texto;
  document.getElementById('bannerOk').classList.add('show');
}
document.getElementById('btnCerrarBanner').addEventListener('click', () => document.getElementById('bannerOk').classList.remove('show'));

function initPagina() {
  if (!esCentral()) {
    document.getElementById('pageContenido').innerHTML = '';
    document.getElementById('pageContenido').appendChild(document.getElementById('tplAccesoNegado').content.cloneNode(true));
    return;
  }
  const cont = document.getElementById('pageContenido');
  cont.innerHTML = '';
  cont.appendChild(document.getElementById('tplPresupuestos').content.cloneNode(true));

  const hoy = new Date();
  const mesActual = `${hoy.getFullYear()}-${String(hoy.getMonth() + 1).padStart(2, '0')}`;
  document.getElementById('genMes').value = mesActual;
  document.getElementById('verMes').value = mesActual;

  document.getElementById('btnGenerar').addEventListener('click', generarPresupuesto);
  document.getElementById('btnImportarHistorico').addEventListener('click', () => document.getElementById('inputHistorico').click());
  document.getElementById('inputHistorico').addEventListener('change', importarHistorico);
  document.getElementById('verMes').addEventListener('change', cargarPresupuesto);
  document.querySelectorAll('.tabs button').forEach(b => b.addEventListener('click', () => cambiarTab(b)));

  cargarTiendas().then(cargarPresupuesto);
}

async function cargarTiendas() {
  const { data } = await sb.from('origenes').select('codigo, nombre').eq('tipo', 'propia').eq('activo', true).order('nombre');
  tiendasCache = data || [];
}

function cambiarTab(btn) {
  document.querySelectorAll('.tabs button').forEach(b => b.classList.remove('activo'));
  btn.classList.add('activo');
  metricaActual = btn.dataset.metrica;
  renderTabla();
}

async function generarPresupuesto() {
  const err = document.getElementById('genErr');
  err.classList.remove('show');
  const mesStr = document.getElementById('genMes').value;
  const pct = Number(document.getElementById('genPct').value || 0);
  if (!mesStr) { err.textContent = 'Selecciona un mes.'; err.classList.add('show'); return; }
  const btn = document.getElementById('btnGenerar');
  btn.disabled = true; btn.textContent = 'Generando...';
  const { data, error } = await sb.rpc('generar_presupuesto', { p_mes: mesStr + '-01', p_pct_crecimiento: pct });
  btn.disabled = false; btn.textContent = 'Generar presupuesto';
  if (error) { err.textContent = 'No se pudo generar: ' + error.message; err.classList.add('show'); return; }
  mostrarBanner(`✅ Presupuesto generado para ${data.tiendas} tienda(s). Los días editados a mano no se tocaron.`);
  document.getElementById('verMes').value = mesStr;
  await cargarPresupuesto();
}

// ─── Importar histórico (CSV: tienda_codigo,fecha,creditos,contado,utilidad) ──
async function importarHistorico(e) {
  const file = e.target.files[0];
  if (!file) return;
  const err = document.getElementById('genErr');
  err.classList.remove('show');
  try {
    const buf = await file.arrayBuffer();
    const wb = XLSX.read(buf, { type: 'array' });
    const ws = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(ws, { defval: null });
    const normalizadas = rows.map(r => {
      const n = {}; for (const k in r) n[String(k).trim().toLowerCase()] = r[k];
      return {
        tienda_codigo: String(n['tienda_codigo'] || n['tienda'] || '').trim(),
        fecha: n['fecha'] ? new Date(n['fecha']).toISOString().slice(0, 10) : null,
        creditos: Number(n['creditos'] || 0),
        contado: Number(n['contado'] || 0),
        utilidad: Number(n['utilidad'] || 0),
      };
    }).filter(r => r.tienda_codigo && r.fecha);
    if (!normalizadas.length) { err.textContent = 'No se encontraron filas válidas (columnas esperadas: tienda_codigo, fecha, creditos, contado, utilidad).'; err.classList.add('show'); return; }
    const { error } = await sb.from('historico_importado').upsert(normalizadas, { onConflict: 'tienda_codigo,fecha' });
    if (error) { err.textContent = 'No se pudo importar: ' + error.message; err.classList.add('show'); return; }
    mostrarBanner(`✅ ${normalizadas.length} fila(s) de histórico importadas. Ahora "Generar presupuesto" las usará como base.`);
  } catch (ex) {
    err.textContent = 'No se pudo leer el archivo: ' + ex.message;
    err.classList.add('show');
  } finally {
    e.target.value = '';
  }
}

// ─── Tabla de presupuesto ────────────────────────────────────────────────
async function cargarPresupuesto() {
  const mesStr = document.getElementById('verMes').value;
  if (!mesStr) return;
  const inicio = mesStr + '-01';
  const [y, m] = mesStr.split('-').map(Number);
  const fin = new Date(y, m, 1).toISOString().slice(0, 10);

  const { data, error } = await sb.from('presupuestos').select('*').gte('fecha', inicio).lt('fecha', fin);
  if (error) { document.getElementById('emptyPresupuesto').style.display = 'block'; document.getElementById('emptyPresupuesto').textContent = 'Error: ' + error.message; return; }
  presupuestoCache = data || [];
  renderTabla();
}

function diasDelMesSeleccionado() {
  const mesStr = document.getElementById('verMes').value;
  const [y, m] = mesStr.split('-').map(Number);
  const dias = new Date(y, m, 0).getDate();
  return { y, m, dias };
}

function renderTabla() {
  const { y, m, dias } = diasDelMesSeleccionado();
  const thead = document.getElementById('theadFila');
  const tbody = document.getElementById('tbodyPresupuesto');
  const empty = document.getElementById('emptyPresupuesto');

  if (!presupuestoCache.length) {
    thead.innerHTML = ''; tbody.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  let headHtml = '<th class="tienda-nombre">Tienda</th>';
  for (let d = 1; d <= dias; d++) {
    const fecha = new Date(y, m - 1, d);
    const esFinde = fecha.getDay() === 0;
    headHtml += `<th class="${esFinde ? 'finde' : ''}">${d}</th>`;
  }
  headHtml += '<th class="total-mes">Total mes</th>';
  thead.innerHTML = headHtml;

  const porTienda = {};
  presupuestoCache.forEach(p => {
    if (!porTienda[p.tienda_codigo]) porTienda[p.tienda_codigo] = {};
    porTienda[p.tienda_codigo][p.fecha] = p;
  });

  tbody.innerHTML = tiendasCache.map(t => {
    let fila = `<td class="tienda-nombre">${escapeHtml(t.nombre)}</td>`;
    let total = 0;
    for (let d = 1; d <= dias; d++) {
      const fechaStr = `${y}-${String(m).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
      const reg = (porTienda[t.codigo] || {})[fechaStr];
      const val = reg ? Number(reg[metricaActual] || 0) : 0;
      total += val;
      const esFinde = new Date(y, m - 1, d).getDay() === 0;
      const esManual = reg && reg.generado_desde === 'manual';
      const mostrar = metricaActual === 'meta_utilidad' ? fmtCOP(val).replace('$', '').replace(/\s/g, '') : val;
      fila += `<td class="dia-celda ${esFinde ? 'finde' : ''} ${esManual ? 'manual' : ''}" data-tienda="${t.codigo}" data-fecha="${fechaStr}" data-nombre="${escapeHtml(t.nombre)}" title="${esManual ? 'Editado manualmente' : 'Generado automáticamente'}">${mostrar}</td>`;
    }
    const totalMostrar = metricaActual === 'meta_utilidad' ? fmtCOP(total) : total;
    fila += `<td class="total-mes">${totalMostrar}</td>`;
    return `<tr>${fila}</tr>`;
  }).join('');

  tbody.querySelectorAll('.dia-celda').forEach(td => td.addEventListener('click', () => abrirModalCelda(td)));
}

function abrirModalCelda(td) {
  celdaEnEdicion = { tienda: td.dataset.tienda, fecha: td.dataset.fecha, nombre: td.dataset.nombre };
  const labels = { meta_creditos: 'Meta de créditos', meta_unidades_contado: 'Meta de unidades contado', meta_utilidad: 'Meta de utilidad' };
  document.getElementById('celdaLabel').textContent = labels[metricaActual];
  document.getElementById('celdaContexto').textContent = `${celdaEnEdicion.nombre} · ${new Date(celdaEnEdicion.fecha + 'T00:00:00').toLocaleDateString('es-CO', { weekday: 'long', day: 'numeric', month: 'long' })}`;
  const reg = presupuestoCache.find(p => p.tienda_codigo === celdaEnEdicion.tienda && p.fecha === celdaEnEdicion.fecha);
  document.getElementById('celdaValor').value = reg ? reg[metricaActual] : 0;
  document.getElementById('celdaErr').classList.remove('show');
  document.getElementById('modalCelda').classList.add('show');
}
document.getElementById('btnCancelarCelda').addEventListener('click', () => document.getElementById('modalCelda').classList.remove('show'));
document.getElementById('btnGuardarCelda').addEventListener('click', guardarCelda);

async function guardarCelda() {
  const err = document.getElementById('celdaErr');
  err.classList.remove('show');
  const valor = Number(document.getElementById('celdaValor').value);
  if (isNaN(valor) || valor < 0) { err.textContent = 'Ingresa un número válido.'; err.classList.add('show'); return; }

  const reg = presupuestoCache.find(p => p.tienda_codigo === celdaEnEdicion.tienda && p.fecha === celdaEnEdicion.fecha);
  const payload = {
    tienda_codigo: celdaEnEdicion.tienda, fecha: celdaEnEdicion.fecha,
    meta_creditos: reg ? reg.meta_creditos : 0,
    meta_unidades_contado: reg ? reg.meta_unidades_contado : 0,
    meta_utilidad: reg ? reg.meta_utilidad : 0,
    generado_desde: 'manual',
  };
  payload[metricaActual] = valor;

  const { error } = await sb.from('presupuestos').upsert(payload, { onConflict: 'tienda_codigo,fecha' });
  if (error) { err.textContent = 'No se pudo guardar: ' + error.message; err.classList.add('show'); return; }
  document.getElementById('modalCelda').classList.remove('show');
  await cargarPresupuesto();
}
</script>
</body>
</html>
