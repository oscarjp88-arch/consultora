<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creditek · Kardex</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="sidebar.js"></script>
<style>
:root {
  --azul: #0B1E3D; --turquesa: #00C4CC; --bg: #F5F5F7; --surface: #FFFFFF;
  --border: rgba(11,30,61,0.08); --text2: #6E6E76; --verde: #16A34A; --amarillo: #D97706; --rojo: #DC2626;
  --radius: 18px; --radius-sm: 11px;
  --shadow-sm: 0 1px 2px rgba(11,30,61,0.04), 0 1px 1px rgba(11,30,61,0.03);
  --shadow-md: 0 12px 28px -10px rgba(11,30,61,0.16);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg); color: var(--azul); -webkit-font-smoothing: antialiased; }

.login-screen { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; background: radial-gradient(circle at 30% 20%, #EAFBFC 0%, var(--bg) 55%); }
.login-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; width: 100%; max-width: 360px; box-shadow: var(--shadow-md); }
.login-box img.logo { display: block; height: 40px; margin: 0 auto 22px; object-fit: contain; }
.login-box input { width: 100%; border: 1px solid transparent; background: var(--bg); border-radius: var(--radius-sm); padding: 13px 14px; font-size: 15px; margin-bottom: 12px; font-family: inherit; transition: all .15s ease; }
.login-box input:focus { outline: none; background: white; border-color: var(--turquesa); box-shadow: 0 0 0 4px rgba(0,196,204,0.14); }
.login-box button { width: 100%; background: var(--turquesa); color: white; border: none; border-radius: var(--radius-sm); padding: 13px; font-size: 14.5px; font-weight: 700; cursor: pointer; margin-top: 6px; box-shadow: 0 6px 16px -4px rgba(0,196,204,0.5); transition: transform .12s ease, box-shadow .12s ease; }
.login-box button:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 8px 20px -4px rgba(0,196,204,0.55); }
.login-box button:disabled { background: #D2D2D7; box-shadow: none; }
.login-err { color: var(--rojo); font-size: 12.5px; margin-top: 10px; display: none; }
.login-err.show { display: block; }

.sin-perfil-screen { min-height: 100vh; display: none; align-items: center; justify-content: center; padding: 20px; text-align: center; }
.sin-perfil-screen.show { display: flex; }
.sin-perfil-box { background: var(--surface); border: 1px solid var(--border); border-radius: 22px; padding: 40px 32px; max-width: 380px; box-shadow: var(--shadow-md); }
.sin-perfil-box .icono { font-size: 34px; margin-bottom: 12px; }
.sin-perfil-box h2 { font-family: 'Montserrat', sans-serif; font-size: 17px; margin-bottom: 8px; }
.sin-perfil-box p { font-size: 13.5px; color: var(--text2); line-height: 1.5; margin-bottom: 18px; }
.sin-perfil-box button { border: 1px solid var(--border); background: var(--bg); border-radius: var(--radius-sm); padding: 10px 18px; font-size: 13px; cursor: pointer; color: var(--azul); font-weight: 600; }

#app { display: none; }
#app.show { display: flex; }

.page { max-width: 1280px; margin: 0 auto; padding: 32px 24px 60px; }
.page-top { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
.page-top h1 { font-family: 'Montserrat', sans-serif; font-size: 22px; font-weight: 800; letter-spacing: -0.02em; }
.btn-primary { background: var(--turquesa); color: white; border: none; border-radius: 999px; padding: 11px 18px; font-size: 13.5px; font-weight: 700; cursor: pointer; box-shadow: 0 6px 16px -4px rgba(0,196,204,0.5); transition: transform .12s ease; }
.btn-primary:hover:not(:disabled) { transform: translateY(-1px); }
.btn-primary:disabled { background: #D2D2D7; box-shadow: none; cursor: not-allowed; }
.btn-secundario { background: var(--bg); color: var(--azul); border: 1px solid var(--border); border-radius: 999px; padding: 9px 16px; font-size: 12.5px; font-weight: 700; cursor: pointer; }
.btn-secundario:hover:not(:disabled) { background: #EAEAEC; }

.banner-ok {
  position: sticky; top: 74px; z-index: 8; margin: 0 auto 18px; max-width: 1280px;
  background: #DCFCE7; color: #166534; border: 1px solid #86EFAC; border-radius: var(--radius-sm);
  padding: 13px 18px; font-size: 13.5px; font-weight: 700; display: none; align-items: center; justify-content: space-between;
  box-shadow: var(--shadow-sm);
}
.banner-ok.show { display: flex; }
.banner-ok button { background: none; border: none; color: #166534; font-weight: 700; cursor: pointer; font-size: 16px; }

.seccion { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-sm); padding: 20px 22px; margin-bottom: 20px; }

.filtros-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 12px; align-items: end; }
.campo { display: flex; flex-direction: column; gap: 6px; position: relative; }
.campo label { font-size: 11px; font-weight: 700; color: var(--text2); text-transform: uppercase; letter-spacing: .03em; }
.campo input, .campo select { border: 1px solid var(--border); background: var(--surface); border-radius: var(--radius-sm); padding: 9px 11px; font-size: 13px; font-family: inherit; color: var(--azul); }
.campo input:focus, .campo select:focus { outline: none; border-color: var(--turquesa); box-shadow: 0 0 0 3px rgba(0,196,204,0.12); }
.preview-producto { display: flex; align-items: center; gap: 6px; margin-top: 4px; font-size: 11.5px; color: var(--text2); }
.preview-producto img { width: 22px; height: 22px; object-fit: cover; border-radius: 4px; }
.filtros-acciones { display: flex; gap: 8px; grid-column: 1 / -1; justify-content: flex-end; }

.info-resultados { font-size: 12.5px; color: var(--text2); margin-bottom: 12px; }

table.kardex-tabla { width: 100%; border-collapse: collapse; font-size: 13px; }
table.kardex-tabla th, table.kardex-tabla td { text-align: left; padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
table.kardex-tabla th { font-size: 10.5px; text-transform: uppercase; letter-spacing: .04em; color: var(--text2); font-weight: 700; background: var(--bg); position: sticky; top: 0; }
table.kardex-tabla tbody tr:hover { background: rgba(0,196,204,0.04); }
.prod-cell { display: flex; align-items: center; gap: 8px; }
.prod-cell img { width: 34px; height: 34px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
.prod-cell .sin-foto { width: 34px; height: 34px; border-radius: 6px; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--text2); flex-shrink: 0; }
.prod-cell .txt { line-height: 1.3; }
.prod-cell .txt .cod { font-size: 11px; color: var(--text2); }
.imei-txt { font-family: 'DM Sans', monospace; font-size: 12px; color: var(--text2); }

.badge-tipo { display: inline-flex; align-items: center; gap: 4px; padding: 4px 10px; border-radius: 999px; font-size: 11.5px; font-weight: 700; white-space: nowrap; }
.badge-tipo.entra { background: #DCFCE7; color: #166534; }
.badge-tipo.sale { background: #FEF2F2; color: var(--rojo); }
.badge-tipo.neutro { background: #E8FBFC; color: var(--azul); }
.badge-tipo.alerta { background: #FEF9C3; color: #92400E; }

.ref-link { color: var(--turquesa); text-decoration: none; font-weight: 600; font-size: 12.5px; }
.ref-link:hover { text-decoration: underline; }
.ref-dir { font-size: 11px; color: var(--text2); margin-left: 4px; }

.empty-state { text-align: center; color: var(--text2); font-size: 13.5px; padding: 40px 0; }
</style>
</head>
<body>

<div class="login-screen" id="loginScreen">
  <div class="login-box">
    <img class="logo" src="https://oscarjp88-arch.github.io/consultora/creditek/agentes/logos/creditek_logo_corregido_alta.png" alt="Creditek">
    <input type="email" id="loginEmail" placeholder="Correo" autocomplete="username">
    <input type="password" id="loginPass" placeholder="Contraseña" autocomplete="current-password">
    <button id="btnLogin">Entrar</button>
    <div class="login-err" id="loginErr"></div>
  </div>
</div>

<div class="sin-perfil-screen" id="sinPerfilScreen">
  <div class="sin-perfil-box">
    <div class="icono">🔒</div>
    <h2>Sin perfil asignado</h2>
    <p>Tu usuario no tiene perfil asignado. Contacta al administrador.</p>
    <button id="btnSalirSinPerfil">Cerrar sesión</button>
  </div>
</div>

<div id="app">
  <div style="display:none;" aria-hidden="true">
    <b id="navNombre"></b><span id="navRolTienda"></span><button id="btnLogout"></button>
  </div>
  <div class="main-content">

  <div class="banner-ok" id="bannerOk">
    <span id="bannerOkTexto"></span>
    <button id="btnCerrarBanner">✕</button>
  </div>

  <div class="page">
    <div class="page-top">
      <h1>📋 Kardex — Historial de movimientos</h1>
    </div>

    <div class="seccion">
      <div class="filtros-grid">
        <div class="campo">
          <label>Producto</label>
          <input type="text" id="filtroProductoTexto" list="datalistProductos" placeholder="Nombre o código..." autocomplete="off">
          <datalist id="datalistProductos"></datalist>
          <div class="preview-producto" id="previewProducto" style="display:none;"></div>
        </div>
        <div class="campo">
          <label>IMEI</label>
          <input type="text" id="filtroImei" placeholder="IMEI exacto..." autocomplete="off">
        </div>
        <div class="campo" id="campoTienda">
          <label>Tienda</label>
          <select id="filtroTienda"><option value="">Todas</option></select>
        </div>
        <div class="campo">
          <label>Desde</label>
          <input type="date" id="filtroDesde">
        </div>
        <div class="campo">
          <label>Hasta</label>
          <input type="date" id="filtroHasta">
        </div>
        <div class="campo">
          <label>Tipo de movimiento</label>
          <select id="filtroTipo"><option value="">Todos</option></select>
        </div>
        <div class="filtros-acciones">
          <button class="btn-secundario" id="btnLimpiarFiltros">Limpiar</button>
          <button class="btn-primary" id="btnBuscar">Buscar</button>
        </div>
      </div>
    </div>

    <div class="info-resultados" id="infoResultados"></div>
    <div class="seccion" style="padding:0; overflow-x:auto;">
      <table class="kardex-tabla">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Tipo</th>
            <th>Producto</th>
            <th>IMEI</th>
            <th>Tienda</th>
            <th>Cantidad</th>
            <th>Costo unitario</th>
            <th>Referencia</th>
          </tr>
        </thead>
        <tbody id="tbodyKardex"></tbody>
      </table>
    </div>
  </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://jfkmiyvcdfbsbwchyvol.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Impma21peXZjZGZic2J3Y2h5dm9sIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQxMzA5NjgsImV4cCI6MjA5OTcwNjk2OH0.kpAjGLbDnycU-B1kc-AqOvj6X2xH-KHBiKB94V7prcQ';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let currentPerfil = null;

function esCentral() { return !!currentPerfil && (currentPerfil.rol === 'gerencia' || currentPerfil.rol === 'auditoria'); }

document.getElementById('btnLogin').addEventListener('click', hacerLogin);
document.getElementById('loginPass').addEventListener('keydown', (e) => { if (e.key === 'Enter') hacerLogin(); });

async function hacerLogin() {
  const email = document.getElementById('loginEmail').value.trim();
  const password = document.getElementById('loginPass').value;
  const btn = document.getElementById('btnLogin');
  const err = document.getElementById('loginErr');
  err.classList.remove('show');
  if (!email || !password) return;
  btn.disabled = true; btn.textContent = 'Entrando...';
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  btn.disabled = false; btn.textContent = 'Entrar';
  if (error) { err.textContent = 'Correo o contraseña incorrectos.'; err.classList.add('show'); return; }
  entrarApp(data.user);
}

document.getElementById('btnLogout').addEventListener('click', cerrarSesion);
document.getElementById('btnSalirSinPerfil').addEventListener('click', cerrarSesion);
async function cerrarSesion() { await sb.auth.signOut(); location.reload(); }

async function entrarApp(user) {
  currentUser = user;
  const { data: perfil, error } = await sb.from('perfiles').select('*').eq('id', user.id).maybeSingle();
  if (error || !perfil || !perfil.activo) {
    document.getElementById('loginScreen').style.display = 'none';
    document.getElementById('sinPerfilScreen').classList.add('show');
    return;
  }
  currentPerfil = perfil;
  document.getElementById('loginScreen').style.display = 'none';
  document.getElementById('app').classList.add('show');
  pintarNavUser();
  initPagina();
}

function pintarNavUser() {
  document.getElementById('navNombre').textContent = currentPerfil.nombre || currentUser.email;
  const rolLabel = { gerencia: 'Gerencia', auditoria: 'Auditoría', admin_tienda: 'Admin tienda', asesor: 'Asesor' }[currentPerfil.rol] || currentPerfil.rol;
  document.getElementById('navRolTienda').textContent = currentPerfil.tienda_codigo ? `${rolLabel} · ${currentPerfil.tienda_codigo}` : rolLabel;
}

sb.auth.getSession().then(({ data }) => { if (data.session) entrarApp(data.session.user); });

function fmtCOP(n) { return new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', maximumFractionDigits: 0 }).format(n || 0); }
function fmtNum(n) { return new Intl.NumberFormat('es-CO').format(n || 0); }
function escapeHtml(str) {
  if (str === null || str === undefined) return '';
  return String(str).replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
}
function mostrarBanner(texto) {
  document.getElementById('bannerOkTexto').textContent = texto;
  document.getElementById('bannerOk').classList.add('show');
}
document.getElementById('btnCerrarBanner').addEventListener('click', () => document.getElementById('bannerOk').classList.remove('show'));

// ─── Página: Kardex ─────────────────────────────────────────────────────
// Nota de esquema real (verificado vía MCP antes de codificar, tabla `movimientos`
// vacía en este momento — 0 filas — así que los tipos NO se leyeron por DISTINCT
// sino del CHECK constraint real `movimientos_tipo_check`, fuente más confiable):
// remision_entrada, venta, traslado_salida, traslado_entrada, ajuste,
// devolucion_reingreso, garantia_salida, garantia_retorno, reverso.
// RLS de `movimientos` YA existe y ya cumple lo pedido (no hubo que crear nada):
// es_central() ve todo, admin_tienda solo tienda_codigo = tienda_actual().
// Cada fila de movimientos tiene UNA sola tienda_codigo (no hay columnas
// "origen"/"destino" en la tabla) — un traslado genera 2 filas (traslado_salida
// en la tienda origen, traslado_entrada en la tienda destino), por eso la
// columna "Tienda" es una sola, con una anotación → / ← para traslados.
const TIPOS_MOVIMIENTO = [
  { valor: 'remision_entrada',    label: '📥 Entrada por remisión', clase: 'entra' },
  { valor: 'venta',               label: '🛒 Venta',                clase: 'sale' },
  { valor: 'traslado_salida',     label: '📤 Traslado — salida',    clase: 'sale' },
  { valor: 'traslado_entrada',    label: '📥 Traslado — entrada',   clase: 'entra' },
  { valor: 'ajuste',              label: '⚖️ Ajuste',               clase: 'alerta' },
  { valor: 'devolucion_reingreso',label: '↩️ Devolución',           clase: 'entra' },
  { valor: 'garantia_salida',     label: '🔧 Garantía — salida',    clase: 'sale' },
  { valor: 'garantia_retorno',    label: '🔧 Garantía — retorno',   clase: 'entra' },
  { valor: 'reverso',             label: '⛔ Reverso',              clase: 'neutro' },
];
function tipoInfo(valor) {
  return TIPOS_MOVIMIENTO.find(t => t.valor === valor) || { label: valor, clase: 'neutro' };
}
const REF_LABEL = { venta: 'Venta', remision: 'Remisión', traslado: 'Traslado', ajuste: 'Ajuste' };
const REF_HREF = { venta: 'ventas.html', remision: 'remisiones.html', traslado: 'traslados.html', ajuste: 'ajustes.html' };

let productosCache = [];
let tiendasCache = [];
let productoSeleccionadoId = null;

function initPagina() {
  document.getElementById('filtroTipo').innerHTML =
    '<option value="">Todos</option>' +
    TIPOS_MOVIMIENTO.map(t => `<option value="${t.valor}">${t.label}</option>`).join('');

  const hoy = new Date();
  const hace30 = new Date(Date.now() - 30 * 86400000);
  document.getElementById('filtroHasta').value = isoFecha(hoy);
  document.getElementById('filtroDesde').value = isoFecha(hace30);

  document.getElementById('btnBuscar').addEventListener('click', buscarMovimientos);
  document.getElementById('btnLimpiarFiltros').addEventListener('click', limpiarFiltros);
  document.getElementById('filtroProductoTexto').addEventListener('input', onProductoTextoChange);
  document.getElementById('filtroImei').addEventListener('keydown', (e) => { if (e.key === 'Enter') buscarMovimientos(); });

  cargarFiltros();
}

function isoFecha(d) { return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }

async function cargarFiltros() {
  const { data: productos } = await sb.from('productos').select('id, codigo, nombre, foto_url').eq('activo', true).order('nombre');
  productosCache = productos || [];
  document.getElementById('datalistProductos').innerHTML =
    productosCache.map(p => `<option value="${escapeHtml(p.codigo)} — ${escapeHtml(p.nombre)}">`).join('');

  // Tienda: PROPIA en minúscula es el valor real en `origenes.tipo` (el paquete
  // decía "PROPIA" en mayúscula; se corrigió al valor real).
  const { data: tiendas } = await sb.from('origenes').select('codigo, nombre').eq('tipo', 'propia').eq('activo', true).order('nombre');
  tiendasCache = tiendas || [];

  if (esCentral()) {
    document.getElementById('filtroTienda').innerHTML =
      '<option value="">Todas</option>' +
      tiendasCache.map(t => `<option value="${escapeHtml(t.codigo)}">${escapeHtml(t.nombre)}</option>`).join('');
  } else {
    // admin_tienda: RLS ya solo le deja ver su propia tienda, así que el
    // selector queda fijo en su tienda (no tiene sentido dejarlo elegir otra).
    const sel = document.getElementById('filtroTienda');
    sel.innerHTML = `<option value="${escapeHtml(currentPerfil.tienda_codigo || '')}">${escapeHtml(nombreTienda(currentPerfil.tienda_codigo))}</option>`;
    sel.disabled = true;
  }

  buscarMovimientos();
}

function nombreTienda(codigo) {
  return tiendasCache.find(t => t.codigo === codigo)?.nombre || codigo || '—';
}

function onProductoTextoChange() {
  const val = document.getElementById('filtroProductoTexto').value;
  const match = productosCache.find(p => `${p.codigo} — ${p.nombre}` === val);
  productoSeleccionadoId = match ? match.id : null;
  const preview = document.getElementById('previewProducto');
  if (match) {
    const foto = match.foto_url
      ? `<img src="${match.foto_url}" alt="">`
      : '';
    preview.innerHTML = `${foto}<span>${escapeHtml(match.nombre)}</span>`;
    preview.style.display = 'flex';
  } else {
    preview.style.display = 'none';
  }
}

function limpiarFiltros() {
  document.getElementById('filtroProductoTexto').value = '';
  productoSeleccionadoId = null;
  document.getElementById('previewProducto').style.display = 'none';
  document.getElementById('filtroImei').value = '';
  if (esCentral()) document.getElementById('filtroTienda').value = '';
  document.getElementById('filtroTipo').value = '';
  const hoy = new Date();
  const hace30 = new Date(Date.now() - 30 * 86400000);
  document.getElementById('filtroHasta').value = isoFecha(hoy);
  document.getElementById('filtroDesde').value = isoFecha(hace30);
  buscarMovimientos();
}

async function buscarMovimientos() {
  const tbody = document.getElementById('tbodyKardex');
  const info = document.getElementById('infoResultados');
  tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state">Buscando...</div></td></tr>';

  const imei = document.getElementById('filtroImei').value.trim();
  let unidadId = null;
  if (imei) {
    const { data: unidad } = await sb.from('unidades').select('id').eq('imei', imei).maybeSingle();
    if (!unidad) {
      tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state">No existe ninguna unidad con ese IMEI.</div></td></tr>';
      info.textContent = '';
      return;
    }
    unidadId = unidad.id;
  }

  let q = sb.from('movimientos')
    .select('id, tipo, tienda_codigo, producto_id, unidad_id, cantidad, costo, precio, referencia_tipo, referencia_id, nota, created_at, productos(nombre, codigo, foto_url), unidades(imei)')
    .order('created_at', { ascending: false })
    .limit(300);

  const tienda = document.getElementById('filtroTienda').value;
  if (tienda) q = q.eq('tienda_codigo', tienda);

  const tipo = document.getElementById('filtroTipo').value;
  if (tipo) q = q.eq('tipo', tipo);

  if (productoSeleccionadoId) q = q.eq('producto_id', productoSeleccionadoId);
  if (unidadId) q = q.eq('unidad_id', unidadId);

  const desde = document.getElementById('filtroDesde').value;
  const hasta = document.getElementById('filtroHasta').value;
  if (desde) q = q.gte('created_at', `${desde}T00:00:00-05:00`);
  if (hasta) q = q.lte('created_at', `${hasta}T23:59:59-05:00`);

  const { data, error } = await q;

  if (error) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty-state">Error: ${escapeHtml(error.message)}</div></td></tr>`;
    info.textContent = '';
    return;
  }

  const movimientos = data || [];

  // Contexto de dirección para traslados (una sola consulta batch, no N+1).
  const idsTraslado = [...new Set(movimientos.filter(m => m.referencia_tipo === 'traslado').map(m => m.referencia_id))];
  let trasladosMap = {};
  if (idsTraslado.length) {
    const { data: traslados } = await sb.from('traslados').select('id, consecutivo, tienda_origen, tienda_destino').in('id', idsTraslado);
    (traslados || []).forEach(t => { trasladosMap[t.id] = t; });
  }

  info.textContent = `${movimientos.length} movimiento${movimientos.length === 1 ? '' : 's'}${movimientos.length === 300 ? ' (límite de 300 — afina los filtros para ver más detalle)' : ''}`;

  if (!movimientos.length) {
    tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state">No hay movimientos con estos filtros.</div></td></tr>';
    return;
  }

  tbody.innerHTML = movimientos.map(m => renderFila(m, trasladosMap)).join('');
}

function renderFila(m, trasladosMap) {
  const fecha = new Date(m.created_at).toLocaleString('es-CO', {
    timeZone: 'America/Bogota', day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit'
  });

  const ti = tipoInfo(m.tipo);
  const badge = `<span class="badge-tipo ${ti.clase}">${ti.label}</span>`;

  const prod = m.productos;
  const foto = prod?.foto_url
    ? `<img src="${prod.foto_url}" alt="">`
    : `<span class="sin-foto">📦</span>`;
  const prodCell = prod
    ? `<div class="prod-cell">${foto}<div class="txt"><div>${escapeHtml(prod.nombre)}</div><div class="cod">${escapeHtml(prod.codigo)}</div></div></div>`
    : '—';

  const imei = m.unidades?.imei ? `<span class="imei-txt">${escapeHtml(m.unidades.imei)}</span>` : '—';

  let refCell = '—';
  if (m.referencia_tipo && REF_LABEL[m.referencia_tipo]) {
    const label = REF_LABEL[m.referencia_tipo];
    const href = REF_HREF[m.referencia_tipo];
    let dir = '';
    if (m.referencia_tipo === 'traslado') {
      const t = trasladosMap[m.referencia_id];
      if (t) {
        dir = m.tipo === 'traslado_salida'
          ? `<span class="ref-dir">→ ${escapeHtml(nombreTienda(t.tienda_destino))}</span>`
          : m.tipo === 'traslado_entrada'
            ? `<span class="ref-dir">← ${escapeHtml(nombreTienda(t.tienda_origen))}</span>`
            : '';
        refCell = `<a class="ref-link" href="${href}">${label} #${t.consecutivo}</a>${dir}`;
      } else {
        refCell = `<a class="ref-link" href="${href}">${label}</a>`;
      }
    } else {
      refCell = `<a class="ref-link" href="${href}">${label}</a>`;
    }
  }

  return `
    <tr>
      <td>${fecha}</td>
      <td>${badge}</td>
      <td>${prodCell}</td>
      <td>${imei}</td>
      <td>${escapeHtml(nombreTienda(m.tienda_codigo))}</td>
      <td>${fmtNum(m.cantidad)}</td>
      <td>${fmtCOP(m.costo)}</td>
      <td>${refCell}</td>
    </tr>
  `;
}
</script>
</body>
</html>
